#!/bin/bash
# ============================================================
# 3hub - 3xui-hub 管理命令
# ============================================================

VERSION="1.0.0"
INSTALL_DIR="/www/wwwroot/3xui-hub"
BACKEND_DIR="${INSTALL_DIR}/backend"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# 检查安装
check_install() {
    if [ ! -f "$BACKEND_DIR/artisan" ]; then
        echo -e "${RED}错误: 3xui-hub 未安装或安装目录不正确${NC}"
        exit 1
    fi
}

# 命令列表（编号对应）
CMDS=(
    "status"
    "check-update"
    "update"
    "admin-user"
    "admin-pass"
    "sync"
    "sync-status"
    "backup"
    "log"
    "restart"
    "ssl"
)

CMD_LABELS=(
    "查看系统状态"
    "检测更新"
    "更新系统"
    "修改管理员账号"
    "修改管理员密码"
    "手动同步流量"
    "查看自动同步状态"
    "导出数据库备份"
    "查看最近错误日志"
    "重启 PHP-FPM 和 Nginx"
    "配置域名和 SSL 证书"
)

# 显示帮助
show_help() {
    echo -e "${CYAN}3hub${NC} - 3xui-hub 管理命令 v${VERSION}"
    echo ""
    echo "用法: 3hub [命令|编号]"
    echo ""
    echo "命令:"
    for i in "${!CMDS[@]}"; do
        printf "  ${GREEN}%2d${NC}  %-14s %s\n" $((i+1)) "${CMDS[$i]}" "${CMD_LABELS[$i]}"
    done
    echo ""
    echo "示例:"
    echo "  3hub status"
    echo "  3hub 1          # 等同于 3hub status"
}

# 查看状态
cmd_status() {
    check_install
    cd "$BACKEND_DIR"

    echo -e "${CYAN}=== 系统状态 ===${NC}"
    echo ""

    # 版本
    echo -e "版本:      ${GREEN}${VERSION}${NC}"

    # PHP
    PHP_VER=$(php -r 'echo PHP_VERSION;' 2>/dev/null)
    echo -e "PHP:       ${GREEN}${PHP_VER}${NC}"

    # 数据库
    if command -v mysql &>/dev/null; then
        DB_SIZE=$(mysql -u root controlhub -e "SELECT ROUND(SUM(data_length + index_length) / 1024 / 1024, 2) AS size_mb FROM information_schema.tables WHERE table_schema = 'controlhub';" -sN 2>/dev/null)
        echo -e "数据库:    ${GREEN}${DB_SIZE} MB (MySQL)${NC}"
    else
        echo -e "数据库:    ${YELLOW}MySQL${NC}"
    fi

    # 统计
    echo ""
    echo -e "${CYAN}--- 数据统计 ---${NC}"
    php artisan tinker --execute="
        echo '用户:      ' . \App\Models\User::count() . PHP_EOL;
        echo '服务器:    ' . \App\Models\Node::count() . PHP_EOL;
        echo '节点:      ' . \App\Models\NodeInbound::count() . PHP_EOL;
        echo '套餐:      ' . \App\Models\Plan::count() . PHP_EOL;
        echo '订单:      ' . \App\Models\Order::count() . PHP_EOL;
        echo '支付配置:  ' . \App\Models\PaymentConfig::count() . PHP_EOL;
    " 2>/dev/null

    # Nginx 状态
    echo ""
    if systemctl is-active nginx &>/dev/null; then
        echo -e "Nginx:     ${GREEN}运行中${NC}"
    else
        echo -e "Nginx:     ${RED}未运行${NC}"
    fi

    # PHP-FPM 状态
    if systemctl is-active php8.4-fpm &>/dev/null || pgrep -f "php-fpm" &>/dev/null; then
        echo -e "PHP-FPM:   ${GREEN}运行中${NC}"
    else
        echo -e "PHP-FPM:   ${RED}未运行${NC}"
    fi
}

# 检测更新
cmd_check_update() {
    check_install
    cd "$INSTALL_DIR"

    echo -e "${CYAN}检查更新...${NC}"
    git fetch origin 2>/dev/null

    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/main 2>/dev/null)

    if [ "$LOCAL" = "$REMOTE" ]; then
        echo -e "${GREEN}已是最新版本${NC}"
    else
        # 检查是否落后于远程（而不是领先）
        BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null)
        if [ "$BEHIND" -gt 0 ] 2>/dev/null; then
            echo -e "${YELLOW}有新版本可用！${NC}（落后 ${BEHIND} 个提交）"
            echo ""
            git log --oneline HEAD..origin/main 2>/dev/null | head -10
            echo ""
            echo -e "运行 ${BLUE}3hub update${NC} 更新"
        else
            echo -e "${GREEN}已是最新版本${NC}（本地领先远程）"
        fi
    fi
}

# 更新系统
cmd_update() {
    check_install
    cd "$INSTALL_DIR"

    echo -e "${CYAN}更新中...${NC}"

    # 重置到远程最新版本（清理本地 merge 提交）
    git fetch origin 2>/dev/null
    git reset --hard origin/main 2>&1

    # 更新后端依赖
    cd "$BACKEND_DIR"
    composer install --no-dev --optimize-autoloader 2>&1

    # 迁移数据库
    php artisan migrate --force 2>&1

    # 清除缓存
    php artisan config:clear 2>&1
    php artisan route:clear 2>&1
    php artisan view:clear 2>&1

    # 复制前端文件
    cp -r "$INSTALL_DIR/frontend/dist/"* "$BACKEND_DIR/public/" 2>/dev/null || true

    # 重启 PHP-FPM
    systemctl reload php8.4-fpm 2>/dev/null || pkill -USR2 php-fpm 2>/dev/null || true

    echo -e "${GREEN}更新完成！${NC}"
}

# 修改管理员账号
cmd_admin_user() {
    check_install
    cd "$BACKEND_DIR"

    echo -e "${CYAN}当前管理员账号:${NC}"
    php artisan tinker --execute="echo \App\Models\Admin::first()->username;" 2>/dev/null
    echo ""
    echo -e "${BLUE}输入新用户名:${NC}"
    read -r NEW_USER

    if [ -z "$NEW_USER" ]; then
        echo -e "${RED}用户名不能为空${NC}"
        return 1
    fi

    if [ ${#NEW_USER} -lt 3 ]; then
        echo -e "${RED}用户名至少3位${NC}"
        return 1
    fi

    php artisan tinker --execute="
        \$admin = \App\Models\Admin::first();
        \$admin->username = '${NEW_USER}';
        \$admin->save();
        echo '已修改为: ' . \$admin->username;
    " 2>/dev/null

    echo -e "${GREEN}管理员账号已修改${NC}"
}

# 修改管理员密码
cmd_admin_pass() {
    check_install
    cd "$BACKEND_DIR"

    echo -e "${BLUE}输入新密码（至少6位）:${NC}"
    read -rs NEW_PASS
    echo ""

    if [ ${#NEW_PASS} -lt 6 ]; then
        echo -e "${RED}密码至少6位${NC}"
        return 1
    fi

    php artisan tinker --execute="
        \$admin = \App\Models\Admin::first();
        \$admin->password = bcrypt('${NEW_PASS}');
        \$admin->save();
        echo '密码已修改';
    " 2>/dev/null

    echo -e "${GREEN}管理员密码已修改${NC}"
}

# 手动同步流量
cmd_sync() {
    check_install
    cd "$BACKEND_DIR"

    echo -e "${CYAN}开始同步流量...${NC}"
    php artisan traffic:sync 2>&1
}

# 查看同步状态
cmd_sync_status() {
    check_install

    echo -e "${CYAN}=== 自动同步状态 ===${NC}"
    echo ""

    # 检查 cron
    if crontab -l 2>/dev/null | grep -q "artisan schedule:run"; then
        echo -e "Cron 定时任务: ${GREEN}已配置${NC}"
    else
        echo -e "Cron 定时任务: ${RED}未配置${NC}"
        echo -e "  修复: crontab -e 添加: * * * * * cd ${BACKEND_DIR} && php artisan schedule:run >> /dev/null 2>&1"
    fi

    # 检查日志中的同步记录
    LOG_FILE="$BACKEND_DIR/storage/logs/laravel.log"
    if [ -f "$LOG_FILE" ]; then
        LAST_SYNC=$(grep -i "traffic:sync\|流量同步\|同步完成" "$LOG_FILE" 2>/dev/null | tail -1)
        if [ -n "$LAST_SYNC" ]; then
            echo ""
            echo -e "最近同步记录:"
            echo "  $LAST_SYNC"
        else
            echo ""
            echo -e "最近同步记录: ${YELLOW}暂无${NC}"
        fi
    fi

    # 检查 Scheduler 运行状态
    echo ""
    cd "$BACKEND_DIR"
    echo -e "${CYAN}调度任务列表:${NC}"
    php artisan schedule:list 2>/dev/null | head -10
}

# 导出备份
cmd_backup() {
    check_install
    cd "$BACKEND_DIR"

    BACKUP_DIR="/tmp/3xui-hub-backup"
    mkdir -p "$BACKUP_DIR"
    BACKUP_FILE="$BACKUP_DIR/backup-$(date +%Y%m%d%H%M%S).sql.gz"

    # mysqldump
    if command -v mysqldump &>/dev/null; then
        mysqldump -u root --single-transaction controlhub 2>/dev/null | gzip > "$BACKUP_FILE"
        echo -e "${GREEN}备份完成: ${BACKUP_FILE}${NC}"
        echo -e "大小: $(du -h "$BACKUP_FILE" | awk '{print $1}')"
    else
        echo -e "${RED}mysqldump 不可用，无法备份${NC}"
        return 1
    fi
}

# 查看日志
cmd_log() {
    check_install
    LOG_FILE="$BACKEND_DIR/storage/logs/laravel.log"

    if [ ! -f "$LOG_FILE" ]; then
        echo -e "${YELLOW}暂无日志${NC}"
        return
    fi

    echo -e "${CYAN}=== 最近错误日志 ===${NC}"
    grep -i "ERROR\|EXCEPTION\|CRITICAL" "$LOG_FILE" 2>/dev/null | tail -20

    if [ ! -s "$LOG_FILE" ]; then
        echo -e "${GREEN}暂无错误${NC}"
    fi
}

# 重启服务

# 配置域名和 SSL
cmd_ssl() {
    check_install
    echo -e "${CYAN}配置域名和 SSL${NC}"
    echo ""
    echo -e "当前配置:"
    CURRENT_URL=$(grep APP_URL "$BACKEND_DIR/.env" 2>/dev/null | cut -d= -f2)
    echo -e "  APP_URL: ${GREEN}$CURRENT_URL${NC}"
    echo ""

    read -rp "请输入域名（直接回车取消）: " DOMAIN
    if [ -z "$DOMAIN" ]; then
        echo -e "${YELLOW}已取消${NC}"
        return 0
    fi

    echo ""
    echo -e "是否开启 SSL？"
    read -rp "(y/N): " SSL_CHOICE

    if [ "$SSL_CHOICE" = "y" ] || [ "$SSL_CHOICE" = "Y" ]; then
        # 安装 acme.sh
        if [ ! -f "$HOME/.acme.sh/acme.sh" ]; then
            echo -e "${BLUE}安装 acme.sh...${NC}"
            curl -s https://get.acme.sh | sh 2>&1 | tail -1
        fi

        # 申请证书（用 pipefail 捕获 acme.sh 真实退出码）
        echo -e "${BLUE}申请 SSL 证书...${NC}"
        set -o pipefail
        ACME_OUTPUT=$($HOME/.acme.sh/acme.sh --issue -d "$DOMAIN" --webroot "$BACKEND_DIR/public" --server letsencrypt 2>&1)
        ACME_EXIT=$?
        set +o pipefail
        echo "$ACME_OUTPUT" | tail -5

        if [ $ACME_EXIT -ne 0 ]; then
            echo -e "${RED}SSL 申请失败，请确保域名已解析到本机 IP${NC}"
            return 1
        fi

        mkdir -p /etc/nginx/ssl
        $HOME/.acme.sh/acme.sh --install-cert -d "$DOMAIN" \
            --key-file /etc/nginx/ssl/${DOMAIN}.key \
            --fullchain-file /etc/nginx/ssl/${DOMAIN}.pem 2>&1 | tail -1

        # 验证证书文件存在
        if [ ! -f "/etc/nginx/ssl/${DOMAIN}.pem" ] || [ ! -f "/etc/nginx/ssl/${DOMAIN}.key" ]; then
            echo -e "${RED}证书文件生成失败${NC}"
            return 1
        fi

        PROTO="https"
        cat > /etc/nginx/conf.d/3xui-hub.conf << 'NGINX_SSL'
server {
    listen 80;
    server_name DOMAIN_PLACEHOLDER;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name DOMAIN_PLACEHOLDER;
    root BACKEND_PLACEHOLDER/public;
    index index.html index.php;

    ssl_certificate /etc/nginx/ssl/DOMAIN_PLACEHOLDER.pem;
    ssl_certificate_key /etc/nginx/ssl/DOMAIN_PLACEHOLDER.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    location ~ [^/]\.php(/|$) {
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    location ~ ^/(api|admin-api) {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(env|git) {
        return 404;
    }
}
NGINX_SSL
        # 替换占位符
        sed -i "s|DOMAIN_PLACEHOLDER|${DOMAIN}|g" /etc/nginx/conf.d/3xui-hub.conf
        sed -i "s|BACKEND_PLACEHOLDER|${BACKEND_DIR}|g" /etc/nginx/conf.d/3xui-hub.conf
    else
        PROTO="http"
        cat > /etc/nginx/conf.d/3xui-hub.conf << 'NGINX_HTTP'
server {
    listen 80;
    server_name DOMAIN_PLACEHOLDER;
    root BACKEND_PLACEHOLDER/public;
    index index.html index.php;

    location ~ [^/]\.php(/|$) {
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    location ~ ^/(api|admin-api) {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(env|git) {
        return 404;
    }
}
NGINX_HTTP
        sed -i "s|DOMAIN_PLACEHOLDER|${DOMAIN}|g" /etc/nginx/conf.d/3xui-hub.conf
        sed -i "s|BACKEND_PLACEHOLDER|${BACKEND_DIR}|g" /etc/nginx/conf.d/3xui-hub.conf
    fi

    # 更新 .env
    sed -i "s|APP_URL=.*|APP_URL=${PROTO}://${DOMAIN}|" "$BACKEND_DIR/.env"

    # 测试并重载
    if nginx -t 2>&1; then
        systemctl reload nginx 2>/dev/null || systemctl start nginx 2>/dev/null
        echo ""
        echo -e "${GREEN}配置完成！${NC}"
        echo -e "访问地址: ${CYAN}${PROTO}://${DOMAIN}/${NC}"
    else
        echo -e "${RED}Nginx 配置错误，请检查${NC}"
        return 1
    fi
}

cmd_restart() {
    echo -e "${CYAN}重启服务...${NC}"

    # PHP-FPM
    if systemctl is-active php8.4-fpm &>/dev/null; then
        systemctl reload php8.4-fpm
        echo -e "PHP-FPM: ${GREEN}已重启${NC}"
    elif pgrep -f "php-fpm" &>/dev/null; then
        pkill -USR2 php-fpm
        echo -e "PHP-FPM: ${GREEN}已重启${NC}"
    fi

    # Nginx
    if systemctl is-active nginx &>/dev/null; then
        systemctl reload nginx
        echo -e "Nginx:   ${GREEN}已重启${NC}"
    fi

    echo -e "${GREEN}服务重启完成${NC}"
}

# 主逻辑
# 支持编号快捷方式
CMD="${1:-help}"
if [[ "$CMD" =~ ^[0-9]+$ ]]; then
    IDX=$((CMD - 1))
    if [ "$IDX" -ge 0 ] && [ "$IDX" -lt "${#CMDS[@]}" ]; then
        CMD="${CMDS[$IDX]}"
    else
        echo -e "${RED}无效编号: $1（1-${#CMDS[@]}）${NC}"
        echo ""
        show_help
        exit 1
    fi
fi

case "$CMD" in
    status)       cmd_status ;;
    check-update) cmd_check_update ;;
    update)       cmd_update ;;
    admin-user)   cmd_admin_user ;;
    admin-pass)   cmd_admin_pass ;;
    sync)         cmd_sync ;;
    sync-status)  cmd_sync_status ;;
    backup)       cmd_backup ;;
    log)          cmd_log ;;
    restart)      cmd_restart ;;
    ssl)          cmd_ssl ;;
    help|--help|-h) show_help ;;
    *)
        echo -e "${RED}未知命令: $CMD${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac
